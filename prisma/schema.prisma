// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------
// ENUMERADORES
// ----------------------------------------------------------------------
enum Rol {
  ADMIN
  OPERADOR
}

enum EstadoTicket {
  PENDIENTE
  ASIGNADO
  EN_PROCESO
  EN_REVISION
  FINALIZADO
}

enum Prioridad {
  CRITICA
  ALTA
  MEDIA
  BAJA
}

// ----------------------------------------------------------------------
// MODELOS
// ----------------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  nombre        String
  correo        String?  @unique
  telefono      String?  @unique
  contrasena    String?  
  rol           Rol      @default(OPERADOR)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Relaciones actualizadas hacia la tabla consolidada
  ticketActivities        TicketActivity[]  @relation("OperadorAsignado")
  comentarios             Comment[]
  transferenciasEnviadas  Transfer[]        @relation("TransferenciaOrigen")
  transferenciasRecibidas Transfer[]        @relation("TransferenciaDestino")
  cambiosHistorial        History[]         @relation("HistorialUsuario")
}

// 1. TABLA CONSOLIDADA: ticket_activity
model TicketActivity {
  id                Int          @id @default(autoincrement())
  codigo            String       @unique // Para códigos como "TK-001"
  titulo            String
  descripcion       String       @db.Text
  prioridad         Prioridad
  estado            EstadoTicket @default(PENDIENTE)
  origen            String       @default("Tickets") // "Tickets", "Manual", etc.
  
  fechaCreacion     DateTime     @default(now())
  fechaLimite       DateTime
  
  // Relación con el Operador asignado (Responsable Actual)
  operadorId        String
  operador          User         @relation("OperadorAsignado", fields: [operadorId], references: [id])

  // Métricas del Historial visibles en tus tarjetas de KPI
  tiempoResolucion  String?      // Ej: "7h 45m"
  numTransferencias Int          @default(0) // Contador de cambios de responsable

  // Relaciones corregidas con sus tipos inversos
  comentarios       Comment[]
  transferencias    Transfer[]
  evidencias        Evidence[]
  historialEventos  History[]

  @@map("ticket_activity")
}

model Comment {
  id        String   @id @default(uuid())
  contenido String   @db.Text
  creadoEn  DateTime @default(now())

  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  
  // Relación corregida apuntando a TicketActivity (Int)
  ticketActivityId Int
  ticketActivity   TicketActivity @relation(fields: [ticketActivityId], references: [id], onDelete: Cascade)
}

model Transfer {
  id          String    @id @default(uuid())
  motivo      String    @db.Text
  
  // ⏱️ Control de tiempos para la auditoría de retrasos
  fechaInicio DateTime  @default(now()) 
  fechaFin    DateTime?           

  // Relación corregida apuntando a TicketActivity (Int)
  ticketActivityId Int
  ticketActivity   TicketActivity @relation(fields: [ticketActivityId], references: [id], onDelete: Cascade)
  
  origenUsuarioId  String?
  origenUsuario    User?     @relation("TransferenciaOrigen", fields: [origenUsuarioId], references: [id])
  
  destinoUsuarioId String
  destinoUsuario   User      @relation("TransferenciaDestino", fields: [destinoUsuarioId], references: [id])
}

model Evidence {
  id            String   @id @default(uuid())
  urlArchivo    String   
  nombreArchivo String
  tipoArchivo   String   
  creadoEn      DateTime @default(now())

  // Relación corregida apuntando a TicketActivity (Int)
  ticketActivityId Int
  ticketActivity   TicketActivity @relation(fields: [ticketActivityId], references: [id], onDelete: Cascade)
}

model History {
  id            String   @id @default(uuid())
  accion        String   
  valorAnterior String?
  valorNuevo    String?
  creadoEn      DateTime @default(now())

  // Relación corregida apuntando a TicketActivity (Int)
  ticketActivityId Int
  ticketActivity   TicketActivity @relation(fields: [ticketActivityId], references: [id], onDelete: Cascade)
  
  usuarioId     String
  usuario       User     @relation("HistorialUsuario", fields: [usuarioId], references: [id])
}